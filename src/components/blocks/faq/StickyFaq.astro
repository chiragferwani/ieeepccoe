---
import SectionSticky from '../../blocks/basic/StickySidebar.astro'
import Header from '../../ui/Header.astro'
import DecorationBorder from '../../ui/DecorationBorder.astro'

type FaqItem = {
	question: string
	answer: string
}

type Props = {
	title?: string
	subtitle?: string
	classes?: string
	items?: FaqItem[]
}

const defaultItems: FaqItem[] = [
	{
		question: 'Who can apply to the PCCOE IEEE Summer School?',
		answer:
			'The summer school is open to B.E./B.Tech students from any engineering college. PCCoE students from all branches are especially encouraged to apply. IEEE Student Members receive priority processing and may be eligible for fee concessions.'
	},
	{
		question: 'What domains or tracks are offered?',
		answer:
			'We offer multiple technical tracks including Artificial Intelligence & Machine Learning, IoT & Embedded Systems, and Web & Cloud Development. Applicants may indicate their preferred track during registration. Allocation is subject to availability.'
	},
	{
		question: 'What is the application fee and how do I pay?',
		answer:
			'The registration fee varies by category (IEEE member, non-member, industry participant). Payment details are provided upon application confirmation. Fee concessions are available for IEEE Student Members. Refer to the Register page for current pricing.'
	},
	{
		question: 'Will I receive a certificate?',
		answer:
			'Yes. Participants who meet attendance requirements and complete the assigned project or assessment will receive an official certificate co-issued by PCCoE and IEEE. Certificate criteria are listed on the Register page.'
	},
	{
		question: 'Is there an accommodation option?',
		answer:
			'Limited on-campus stay options may be available for outstation participants. Please indicate your requirement in the registration form. Hostel allocation is subject to availability and is confirmed separately.'
	},
	{
		question: 'Can I cancel my registration?',
		answer:
			'Cancellation requests must be submitted at least [X days] before the programme start date. Refer to our Terms page for the full cancellation and refund policy.'
	}
]

const { title = '', subtitle = '', classes = '', items = defaultItems } = Astro.props
---

<SectionSticky classes={`${classes ? classes : ''}`}>
	<Header
		title={title}
		subtitle={subtitle}
		headingLevel="h2"
		titleClasses="bg-white dark:bg-neutral-950 "
		slot="sidebar"
	/>

	<div class="faq" id="faq">
		{
			items.map((item) => (
				<div class="faq__item">
					<h3 class="faq__item__title">{item.question}</h3>
					<p class="faq__item__text">{item.answer}</p>
					<DecorationBorder type="top bottom" style="dashed" />
				</div>
			))
		}
	</div>
</SectionSticky>

<style>
	@reference '../../../styles/global.css';
	.faq {
		@apply flex flex-col gap-6 lg:gap-8;
	}
	.faq__item {
		@apply relative bg-white p-6 lg:p-8 dark:bg-neutral-950;
	}
	.faq__item__title {
		@apply mb-2 text-2xl leading-8;
	}
	.faq__item__text {
		@apply mb-0 text-xl leading-8;
	}
</style>
