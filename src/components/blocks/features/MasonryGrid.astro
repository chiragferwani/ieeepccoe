---
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import { Image } from 'astro:assets'
import FeatureCard from '../../ui/cards/FeatureImageCard.astro'

import feature01Front from '../../../assets/features/masonry/feature_01_front.webp'
import feature01Back from '../../../assets/features/masonry/feature_01_back.webp'
import feature02Front from '../../../assets/features/masonry/feature_02_front.webp'
import feature02Back from '../../../assets/features/masonry/feature_02_back.webp'
import feature03Front from '../../../assets/features/masonry/feature_03_front.webp'
import feature03Back from '../../../assets/features/masonry/feature_03_back.webp'
import feature04Front from '../../../assets/features/masonry/feature_04_front.webp'
import feature04Back from '../../../assets/features/masonry/feature_04_back.webp'
---

<Section>
	<Row classes="">
		<Col span="4">
			<FeatureCard style="solid" classes="h-full" decorationType="all" parallaxOffset="20">
				<div slot="content" class="max-w-xl">
					<h3>Expert-Led Sessions</h3>
					<p>
						Learn from faculty, industry professionals, and researchers across specialised technical
						domains with a curriculum designed for real-world impact.
					</p>
				</div>
				<div slot="bg-front">
					<Image src={feature01Front} alt="Expert-led session" loading="lazy" decoding="async" layout="constrained" class="feature__image" height={300} />
				</div>
				<div slot="bg-back">
					<Image src={feature01Back} alt="Expert-led session" loading="lazy" decoding="async" layout="constrained" class="feature__image" height={300} />
				</div>
			</FeatureCard>
		</Col>
		<Col span="8">
			<FeatureCard classes="h-full" parallaxOffset="50" style="solid" decorationType="all">
				<div slot="content" class="max-w-lg">
					<h3>Hands-On Learning</h3>
					<p>
						Move beyond theory. Every domain includes labs, tool demos, and project-based tasks
						designed to make learning stick.
					</p>
				</div>
				<div slot="bg-front">
					<Image src={feature02Front} alt="Hands-on labs" loading="lazy" decoding="async" layout="constrained" class="feature__image" height={300} />
				</div>
				<div slot="bg-back">
					<Image src={feature02Back} alt="Hands-on labs" loading="lazy" decoding="async" layout="constrained" class="feature__image" height={300} />
				</div>
			</FeatureCard>
		</Col>
		<Col span="8">
			<FeatureCard style="solid" classes="h-full" decorationType="all" parallaxOffset="20">
				<div slot="content" class="max-w-xl">
					<h3>Certificate & Credits</h3>
					<p>
						Earn a certificate of participation after meeting attendance and project criteria.
						Credits transfer options are available for enrolled PCCoE students.
					</p>
				</div>
				<div slot="bg-front">
					<Image src={feature03Front} alt="Certificate and credits" loading="lazy" decoding="async" layout="constrained" class="feature__image" height={300} />
				</div>
				<div slot="bg-back">
					<Image src={feature03Back} alt="Certificate and credits" loading="lazy" decoding="async" layout="constrained" class="feature__image" height={300} />
				</div>
			</FeatureCard>
		</Col>
		<Col span="4">
			<FeatureCard style="solid" classes="h-full" decorationType="all" parallaxOffset="20">
				<div slot="content" class="max-w-lg">
					<h3>Networking & Community</h3>
					<p>
						Connect with like-minded peers, join the IEEE student community, and grow your
						professional network across engineering branches.
					</p>
				</div>
				<div slot="bg-front">
					<Image src={feature04Front} alt="Networking and community" loading="lazy" decoding="async" layout="constrained" class="feature__image" height={300} />
				</div>
				<div slot="bg-back">
					<Image src={feature04Back} alt="Networking and community" loading="lazy" decoding="async" class="feature__image" layout="constrained" height={300} />
				</div>
			</FeatureCard>
		</Col>
	</Row>
</Section>

<style>
	@reference '../../../styles/global.css';
	.feature__image {
		@apply ml-auto max-w-none! lg:max-w-full!;
	}
</style>
