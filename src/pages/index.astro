---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/blocks/hero/CenteredHeroCTA.astro'
import Brand from '../components/blocks/brand/Marquee.astro'
import Features from '../components/blocks/features/MasonryGrid.astro'
import ScrollSpySteps from '../components/blocks/onboarding/Steps.astro'
import TestimonialMasonry from '../components/blocks/testimonials/TestimonialMasonry.astro'
import Faq from '../components/blocks/faq/StickyFaq.astro'
import CTA from '../components/blocks/cta/CTAPrimary.astro'
import heroBanner from '../assets/hero/macbook.webp'

const SEO = {
	title: 'PCCOE Summer School',
	description:
		'The Official PCCOE IEEE Summer School. Join expert-led sessions, hands-on labs, and deep-dive technical domains at Pimpri Chinchwad College of Engineering, Pune.'
}

const heroData = {
	title: 'Learn Deeper. Build Faster.',
	subtitle: 'A Multi-Day Intensive Summer School by PCCoE IEEE Student Branch',
	text: 'Join engineers, researchers, and innovators for hands-on sessions, expert talks, and domain deep-dives - all under one roof at Pimpri Chinchwad College of Engineering, Pune.',
	buttonLink: '/register',
	buttonText: 'Apply Now →',
	image: heroBanner
}

const brandData = {
	title: 'Supported & Recognized By'
}

const testimonialData = {
	title: 'What Past Participants Say',
	subtitle: 'Student & Faculty Voices'
}

const faqData = {
	title: 'Frequently Asked Questions',
	subtitle: 'Everything you need to know about the Summer School'
}

const ctaData = {
	title: 'Secure Your Spot at PCCoE IEEE Summer School',
	text: "Limited seats per batch. Applications are reviewed on a rolling basis - the sooner you apply, the better your chances of getting your preferred domain. Don't miss this chance to learn, build, and connect.",
	buttonLink: '/register',
	buttonText: 'Apply Now →'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero
		title={heroData.title}
		subtitle={heroData.subtitle}
		text={heroData.text}
		buttonLink={heroData.buttonLink}
		buttonText={heroData.buttonText}
		image={heroData.image}
	/>
	<Brand title={brandData.title} />
	<Features />
	<ScrollSpySteps />
	<TestimonialMasonry title={testimonialData.title} subtitle={testimonialData.subtitle} />
	<Faq subtitle={faqData.subtitle} title={faqData.title} />
	<CTA
		title={ctaData.title}
		text={ctaData.text}
		buttonLink={ctaData.buttonLink}
		buttonText={ctaData.buttonText}
	/>
</Layout>
