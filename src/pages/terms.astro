---
import Layout from '../layouts/Layout.astro'
import Row from '../components/ui/Row.astro'
import Col from '../components/ui/Col.astro'
import Hero from '../components/blocks/hero/SimpleHeroNeutral.astro'
import SectionSticky from '../components/blocks/basic/StickySidebarTransparent.astro'
import Header from '../components/ui/Header.astro'

const SEO = {
	title: 'Terms & Conditions | PCCOE Summer School',
	description:
		'Read the terms and conditions for PCCOE Summer School regarding registration, attendance, payments, and certification.'
}

const heroData = {
	title: 'Terms & Conditions',
	subtitle: 'Event Policy',
	text: 'Please review these terms before applying to PCCoE IEEE Summer School. Your application and participation indicate acceptance of this policy.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero title={heroData.title} subtitle={heroData.subtitle} text={heroData.text} textClasses="max-w-xl!" />
	<SectionSticky>
		<Header title="Registration Terms" subtitle="Eligibility & Confirmation" headingLevel="h2" titleClasses="bg-white dark:bg-neutral-950 text-3xl lg:text-5xl break-words text-balance hyphens-auto" slot="sidebar" />
		<Row decorationBorder="top bottom" decorationBorderStyle="dashed" style="transparent">
			<Col span="12" style="transparent">
				<div class="text-basic bg-white p-8 dark:bg-neutral-950 [&_h3]:text-xl!">
					<h3>Eligibility</h3>
					<p>The programme is open to B.E./B.Tech students and selected faculty or industry participants as listed on the Register page. Providing incorrect information may lead to rejection or cancellation.</p>
					<h3>Application & Confirmation</h3>
					<p>Registration is completed through the official Google Form. Submission does not guarantee a seat. Seats are allocated on a batch-wise, availability-based process after review by the organising team.</p>
					<h3>Communication</h3>
					<p>All official updates, payment instructions, and batch details are shared through the registered email address. Participants are responsible for checking mail and responding within required timelines.</p>
				</div>
			</Col>
		</Row>
	</SectionSticky>
	<SectionSticky>
		<Header title="Payments & Refunds" subtitle="Fees and Cancellation" headingLevel="h2" titleClasses="bg-white dark:bg-neutral-950 text-3xl lg:text-5xl break-words text-balance hyphens-auto" slot="sidebar" />
		<Row decorationBorder="top bottom" decorationBorderStyle="dashed" style="transparent">
			<Col span="12" style="transparent">
				<div class="text-basic bg-white p-8 dark:bg-neutral-950 [&_h3]:text-xl!">
					<h3>Fee Payment</h3>
					<p>Payment must be made only after confirmation from the organising team. Accepted methods include UPI, NEFT, or approved offline payment channels communicated in the confirmation message.</p>
					<h3>Cancellation Policy</h3>
					<p>Cancellation requests must be submitted at least [X days] before programme start for refund consideration. Approved cancellations may receive up to [X]% refund based on administrative deductions.</p>
					<h3>Non-Refund Cases</h3>
					<p>No refund is guaranteed after the published cutoff date, for no-show participants, or for removals due to disciplinary violations or false declarations in the application form.</p>
				</div>
			</Col>
		</Row>
	</SectionSticky>
	<SectionSticky>
		<Header title="Participation & Certification" subtitle="Attendance and Conduct" headingLevel="h2" titleClasses="bg-white dark:bg-neutral-950 text-3xl lg:text-5xl break-words text-balance hyphens-auto" slot="sidebar" />
		<Row decorationBorder="top bottom" decorationBorderStyle="dashed" style="transparent">
			<Col span="12" style="transparent">
				<div class="text-basic bg-white p-8 dark:bg-neutral-950 [&_h3]:text-xl!">
					<h3>Attendance Requirement</h3>
					<p>Certification is issued only to participants meeting attendance and project or assessment requirements communicated for each domain.</p>
					<h3>Code of Conduct</h3>
					<p>Participants are expected to maintain professional behaviour in sessions, labs, and campus premises. Harassment, misuse of facilities, or academic misconduct may lead to disqualification.</p>
					<h3>Policy Updates</h3>
					<p>The organising team may revise schedules, faculty lineup, infrastructure details, or policy clauses based on operational requirements. Updated terms become effective once published on official channels.</p>
				</div>
			</Col>
		</Row>
	</SectionSticky>
</Layout>
