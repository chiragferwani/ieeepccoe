---
import Layout from '../../layouts/Layout.astro'
import Hero from '../../components/blocks/hero/SimpleHeroBasic.astro'
import PostCards from '../../components/blocks/blog/PostCards.astro'
import { getCollection } from 'astro:content'

export async function getStaticPaths({ paginate }: any) {
	const allPosts = await getCollection('blog', ({ id }) => id)
	return paginate(allPosts, { pageSize: 100 })
}
const { page } = Astro.props as any

const SEO = {
	title: 'PCCoE IEEE Summer School | Updates & Gallery',
	description:
		'Latest announcements, speaker reveals, and gallery highlights from PCCoE IEEE Summer School.'
}

const sortedBlogPosts = page.data.sort((a: any, b: any) => {
	return new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
})
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero
		subtitle="Latest from the Summer School"
		title="Updates & Announcements"
		text="Track key announcements, speaker updates, and event highlights from the PCCoE IEEE Summer School edition."
	/>
	<PostCards data={sortedBlogPosts} />
</Layout>
