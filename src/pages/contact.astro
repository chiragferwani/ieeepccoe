---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/blocks/hero/SimpleHeroBasic.astro'
import ContactInfo from '../components/blocks/contact/ContactInfoCards.astro'
import Brand from '../components/blocks/brand/Marquee.astro'
import Faq from '../components/blocks/faq/StickyFaq.astro'
import CTA from '../components/blocks/cta/CTAPrimary.astro'

const SEO = {
	title: 'PCCoE IEEE Summer School | Contact Us',
	description:
		'Contact the PCCoE IEEE Summer School team for registration, programme, accommodation, and event details.'
}

const heroData = {
	title: 'Get in Touch',
	subtitle: "We're happy to help",
	text: 'Have questions about registration, domains, accommodation, or anything else? Fill out the form below or reach us directly.'
}

const contactData = {
	title: 'Contact details, event information, and social channels'
}

const brandData = {
	title: 'Supported & Recognized By'
}

const faqData = {
	title: 'Frequently Asked Questions',
	subtitle: 'Everything you need to know about the Summer School'
}

const ctaData = {
	title: 'Apply and Build with PCCoE IEEE Summer School',
	text: 'If you are ready to participate, complete your registration early to improve your chances of getting your preferred domain.',
	buttonLink: '/register',
	buttonText: 'Apply Now →'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero title={heroData.title} subtitle={heroData.subtitle} text={heroData.text} />
	<ContactInfo title={contactData.title} />
	<Brand title={brandData.title} />
	<Faq subtitle={faqData.subtitle} title={faqData.title} />
	<CTA
		title={ctaData.title}
		text={ctaData.text}
		buttonLink={ctaData.buttonLink}
		buttonText={ctaData.buttonText}
	/>
</Layout>
