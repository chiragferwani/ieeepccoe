---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/blocks/hero/SimpleHeroNeutral.astro'

const SEO = {
	title: 'PCCoE IEEE Summer School | Conditions',
	description: 'Additional programme conditions for attendance, conduct, and event operations.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero
		title="Conditions"
		subtitle="Participation Conditions"
		text="Participants must comply with published schedules, venue rules, and code of conduct. Operational details may change based on academic and institutional requirements."
	/>
</Layout>
